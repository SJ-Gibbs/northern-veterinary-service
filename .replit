run = "npm run dev"
modules = ["nodejs-20"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["npm", "run", "dev"]

[[ports]]
localPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Preview Website"

[[workflows.workflow]]
name = "Preview Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node preview-server.cjs"
waitForPort = 5000
