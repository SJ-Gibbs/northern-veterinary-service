# Server
PORT=3000
NODE_ENV=development

# MySQL (Hostinger hPanel)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Master admin (must match seeded user email; full admin + diary powers)
MASTER_ADMIN_EMAIL=info@northernveterinaryservice.co.uk

# Optional: allow public self-registration (team + practice) at POST /api/auth/register
# Set to "false" on production if only admin creates accounts.
ALLOW_PUBLIC_SIGNUP=true

# Trust first proxy (Hostinger / reverse proxy) — set true in production behind HTTPS
TRUST_PROXY=false

# Site access gate credentials (enter.html pre-login layer)
# Pick any username and a strong password — these are NOT stored in the DB.
SITE_GATE_USER=nvs
SITE_GATE_PASS=change-this-site-password

# SMTP — used to send account verification emails.
# Any standard SMTP provider works (e.g. Hostinger webmail, Brevo, Mailgun, etc.).
# Port 587 uses STARTTLS (recommended). Port 465 uses implicit TLS (set SMTP_PORT=465).
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@northernveterinaryservice.co.uk
SMTP_PASS=your-smtp-password
# Optional: override the From address shown in emails.
SMTP_FROM=Northern Veterinary Service <noreply@northernveterinaryservice.co.uk>

# Public URL of this app — used to build the verification link inside emails.
APP_URL=https://northernveterinaryservice.co.uk
